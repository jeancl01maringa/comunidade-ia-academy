generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER") // ADMIN, USER
  status        String    @default("ACTIVE") // ACTIVE, EXPIRED, BLOCKED
  origin        String    @default("DIRECT") // DIRECT, HOTMART, KIWIFY, GREEN
  phone         String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  images        Image[]   
  payments      Payment[]
  subscriptions Subscription[]
  likes         Like[]
  saves         Save[]
}

model Plan {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  price             Float
  originalPrice     Float?
  interval          String   @default("month") // month, year
  discountPercentage Int?
  features          String[] // List of features
  isPopular         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  subscriptions     Subscription[]
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String    
  planId      String
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  startDate   DateTime  @default(now())
  endDate     DateTime?
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        Plan      @relation(fields: [planId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([planId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Image {
  id          String   @id @default(cuid())
  title       String?  // SEO Title
  url         String
  prompt      String   @db.Text
  visible     Boolean  @default(true)
  status      String   @default("APPROVED") // APPROVED, PENDING, REJECTED
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  aiModelId   String?
  aiModel     AIModel? @relation(fields: [aiModelId], references: [id])

  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  // Stats
  views       Int      @default(0)
  copyCount   Int      @default(0)
  
  likes       Like[]
  saves       Save[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([aiModelId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  imageId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, imageId])
}

model Save {
  id        String   @id @default(cuid())
  userId    String
  imageId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, imageId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIModel {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "Midjourney v6"
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id            String   @id @default(cuid())
  gateway       String   @unique // HOTMART, KIWIFY, GREEN
  apiKey        String?
  webhookSecret String?
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  externalId    String   @unique // ID from the gateway
  amount        Float
  status        String   // paid, pending, refunded
  gateway       String
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ToolCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id             String       @id @default(cuid())
  name           String
  url            String
  description    String?      @db.Text
  imageUrl       String?
  isNew          Boolean      @default(false)
  isActive       Boolean      @default(true)
  categoryId     String?
  category       ToolCategory? @relation(fields: [categoryId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
